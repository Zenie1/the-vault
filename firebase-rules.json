{
  "rules": {
    ".read":  false,
    ".write": false,

    // Admin config — adminHash is the SHA-256 hash of the admin password.
    // .read: true — the browser must fetch the hash to compare against user input.
    //   A SHA-256 hash is a one-way function; reading the hash does not reveal the password.
    // .write: "auth != null" — any authenticated (anonymous) session may write.
    //   The app enforces "verify current password first" before allowing a change.
    "vault-config": {
      "adminHash": {
        ".read":  true,
        ".write": "auth != null"
      }
    },

    "sessions": {
      "$roomCode": {

        // Any signed-in user (including anonymous) can read the session.
        ".read": "auth != null",

        // Any authenticated user can create or delete a session document.
        ".write": "auth != null",

        "hostId": {
          // hostId can only be written if:
          //   • the field doesn't exist yet (initial session creation), OR
          //   • the current auth user IS the existing host
          ".validate": "!data.exists() || auth.uid == data.val()"
        },

        "state": {
          // Only the session host may push playback state.
          ".validate": "newData.exists() ? auth.uid == root.child('sessions').child($roomCode).child('hostId').val() : true",

          "trackId":    { ".validate": "newData.isString()" },
          "isPlaying":  { ".validate": "newData.isBoolean()" },
          "currentTime":{ ".validate": "newData.isNumber()" },
          "timestamp":  { ".validate": "newData.isNumber()" },

          "stems": {
            "$stem": {
              "muted":  { ".validate": "newData.isBoolean()" },
              "volume": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" }
            }
          }
        },

        "messages": {
          // Both host and guest can read messages for this session.
          ".read": "auth != null",

          // Any authenticated user in this session can write messages.
          // TODO: tighten to hostId/guestId check after testing.
          ".write": "auth != null",

          "$messageId": {
            "uid":  { ".validate": "newData.isString() && (newData.val() == 'host' || newData.val() == 'guest')" },
            "text": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 280" },
            "timestamp": { ".validate": "newData.isNumber()" }
          }
        },

        "typing": {
          // Both parties can read and write typing state.
          ".read":  "auth != null",
          ".write": "auth != null",

          "host":  { ".validate": "newData.isBoolean()" },
          "guest": { ".validate": "newData.isBoolean()" }
        }

      }
    }
  }
}
